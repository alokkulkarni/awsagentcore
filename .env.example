AWS_REGION=eu-west-2

# ---------------------------------------------------------------------------
# AWS Credentials — resolution order (highest → lowest priority):
#   1. AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY + AWS_SESSION_TOKEN (env vars)
#   2. AWS_PROFILE (named profile in ~/.aws/credentials)
#   3. [default] profile in ~/.aws/credentials
#   4. IAM instance role (EC2 / ECS / Lambda metadata)
#   5. AWS SSO / credential_process in ~/.aws/config
# Leave AWS_PROFILE blank to use the default profile or instance role.
# ---------------------------------------------------------------------------
AWS_PROFILE=

# Optional: assume an IAM role after resolving base credentials (cross-account etc.)
# Leave blank to use the resolved credentials directly.
AWS_ROLE_ARN=
AWS_ROLE_SESSION_NAME=aria-banking-agent

# ---------------------------------------------------------------------------
# Bedrock model — auto-resolved per region if left blank.
#   Default for all regions: anthropic.claude-sonnet-4-6
#   Override only if you need a specific versioned model ID.
# ---------------------------------------------------------------------------
BEDROCK_MODEL_ID=

BANK_API_BASE_URL=https://api.meridianbank.internal
BANK_API_KEY=your-api-key-here
PII_VAULT_BACKEND=in_memory  # in_memory | aws_secrets_manager | hashicorp_vault
LOG_LEVEL=INFO
LOG_DIR=.  # Directory for aria.log (defaults to current directory)
